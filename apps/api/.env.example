# App
NODE_ENV=development
PORT=3001
APP_PREFIX=api/v1
WEB_ORIGIN=http://localhost:3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=aswaq
# dev: auto-create schema from entities. PRODUCTION: set false and use migrations.
DB_SYNCHRONIZE=true
DB_LOGGING=false

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d
